<!DOCTYPE html>
<html lang="{{ lang }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="description" content="{{ description }}">
  <title>{{ title }}</title>

  <!-- Canonical & hreflang -->
  <link rel="canonical" href="https://herbarius.fr/{{ lang }}/{{ pageSlug }}.html">
  <link rel="alternate" hreflang="fr" href="https://herbarius.fr/fr/{{ pageSlug }}.html">
  <link rel="alternate" hreflang="en" href="https://herbarius.fr/en/{{ pageSlug }}.html">
  <link rel="alternate" hreflang="x-default" href="https://herbarius.fr/fr/{{ pageSlug }}.html">

  <!-- Open Graph -->
  <meta property="og:type" content="website">
  <meta property="og:locale" content="{% if lang == 'fr' %}fr_FR{% else %}en_GB{% endif %}">
  <meta property="og:site_name" content="Herbarius">
  <meta property="og:title" content="{{ title }}">
  <meta property="og:description" content="{{ description }}">
  <meta property="og:url" content="https://herbarius.fr/{{ lang }}/{{ pageSlug }}.html">
  <meta property="og:image" content="https://herbarius.fr/images/jardin/jardin_vue_haut.jpg">

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{ title }}">
  <meta name="twitter:description" content="{{ description }}">
  <meta name="twitter:image" content="https://herbarius.fr/images/jardin/jardin_vue_haut.jpg">

  <!-- Favicon & fonts -->
  <link rel="icon" href="../favicon.ico" sizes="any">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;600;700&family=Source+Sans+3:wght@400;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="../css/style.css">
</head>
<body>

  <!-- ========== HEADER ========== -->
  <header class="site-header">
    <div class="container header-inner">
      <a href="index.html" class="logo">
        <span class="logo-text">Herbarius</span>
        <span class="logo-tagline">{{ i18n[lang].logoTagline }}</span>
      </a>
      <button class="nav-toggle" aria-label="{{ i18n[lang].menuLabel }}" aria-expanded="false">
        <span class="nav-toggle-icon"></span>
      </button>
      <nav aria-label="{{ i18n[lang].navLabel }}">
        <ul class="nav-links">
          {%- set navItems = [
            {slug: "index", page: "index"},
            {slug: "programme", page: "programme"},
            {slug: "activites", page: "activites"},
            {slug: "hebergements", page: "hebergements"},
            {slug: "visite-virtuelle", page: "visite-virtuelle"},
            {slug: "contact", page: "contact"}
          ] -%}
          {%- for item in navItems %}
          <li><a href="{{ item.page }}.html"{% if navCurrent == item.slug %} aria-current="page"{% endif %}>{{ i18n[lang].nav[item.slug] }}</a></li>
          {%- endfor %}
          <li class="nav-lang"><a href="../{{ otherLang }}/{{ pageSlug }}.html" title="{{ i18n[lang].langSwitchTitle }}">{{ i18n[lang].langSwitchFlag }} {{ i18n[lang].langSwitchLabel }}</a></li>
        </ul>
      </nav>
    </div>
  </header>

  {{ content | safe }}

  <!-- ========== FOOTER ========== -->
  <footer class="site-footer">
    <div class="container footer-grid">

      <div class="footer-col">
        <h4>{{ i18n[lang].footer.activites }}</h4>
        <ul>
          <li><a href="visites-botaniques.html">{{ i18n[lang].footer.visitesBot }}</a></li>
          <li><a href="ateliers.html">{{ i18n[lang].footer.ateliers }}</a></li>
          <li><a href="conferences.html">{{ i18n[lang].footer.conferences }}</a></li>
          <li><a href="conception.html">{{ i18n[lang].footer.conception }}</a></li>
          <li><a href="vente-plantes.html">{{ i18n[lang].footer.ventePlantes }}</a></li>
        </ul>
      </div>

      <div class="footer-col">
        <h4>{{ i18n[lang].footer.hebergements }}</h4>
        <ul>
          <li><a href="hebergements.html">{{ i18n[lang].footer.cabane }}</a></li>
          <li><a href="hebergements.html">{{ i18n[lang].footer.tente }}</a></li>
          <li><a href="hebergements.html">{{ i18n[lang].footer.camping }}</a></li>
        </ul>
      </div>

      <div class="footer-col">
        <h4>{{ i18n[lang].footer.horaires }}</h4>
        <p><strong>{{ i18n[lang].footer.pepiniere }}</strong> {{ i18n[lang].footer.pepiHoraires }}</p>
        <p><strong>{{ i18n[lang].footer.visites }}</strong> {{ i18n[lang].footer.visitesHoraires }}</p>
      </div>

      <div class="footer-col">
        <h4>{{ i18n[lang].footer.contact }}</h4>
        <address>
          <p>Florence GOULLEY</p>
          <p>704 Le Haut du Val</p>
          <p>Planguenoual</p>
          <p>22400 Lamballe Armor</p>
          <p><a href="mailto:f.goulley@herbarius.net">f.goulley@herbarius.net</a></p>
          <p><a href="tel:+33603432528">06 03 43 25 28</a></p>
        </address>
      </div>

    </div>

    <div class="footer-bottom">
      <div class="container">
        <p>HERBARIUS | Florence GOULLEY | herbarius.net</p>
      </div>
    </div>
  </footer>

  <!-- JSON-LD Structured Data -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "TouristAttraction",
    "additionalType": "https://schema.org/LocalBusiness",
    "name": "Herbarius",
    "description": "{% if lang == 'fr' %}Jardin botanique médiéval à Planguenoual, Bretagne. Plantes médicinales, aromatiques et comestibles.{% else %}Medieval botanical garden in Planguenoual, Brittany. Medicinal, aromatic and edible plants.{% endif %}",
    "url": "https://herbarius.fr",
    "image": "https://herbarius.fr/images/jardin/jardin_vue_haut.jpg",
    "telephone": "+33603432528",
    "email": "f.goulley@herbarius.net",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "704 Le Haut du Val",
      "addressLocality": "Planguenoual",
      "postalCode": "22400",
      "addressRegion": "Bretagne",
      "addressCountry": "FR"
    },
    "geo": {
      "@type": "GeoCoordinates",
      "latitude": 48.5228,
      "longitude": -2.5906
    },
    "sameAs": []
  }
  </script>

  <script src="../js/main.js"></script>
</body>
</html>
